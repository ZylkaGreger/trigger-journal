# ─────────────────────────────────────────────────────────────
# DATENSCHUTZ-WALL — sehr wichtig.
# Geteilt wird das WERKZEUG, niemals deine Einträge.
# Deine intimen Daten landen NIE auf GitHub.
# ─────────────────────────────────────────────────────────────

# Alle echten Einträge ignorieren ...
entries/*

# ... aber den Ordner selbst und das Beispiel behalten,
# damit das Repo verständlich bleibt.
!entries/.gitkeep

# Wochen-Reflexionen — genauso privat wie die Einträge, NIE teilen
reflections/

# Lokale Exporte / Backups
exports/
*.backup.json

# Podcast-Transkripte (Sounds True) — urheberrechtlich geschützt,
# nur lokal für den privaten Gebrauch, NIE committen
reference/transcripts/

# Singer-Wissensbasis (aus den Transkripten destilliert) — ebenfalls nur lokal
reference/singer-knowledge/

# Human Design — enthält persönliche Geburtsdaten (PII), nur lokal, NIE committen
reference/human-design/

# Destillierte Singer-Wissensbasis — enthält Original-Zitate aus den
# Transkripten, ebenfalls nur lokal
reference/singer-knowledge/

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
